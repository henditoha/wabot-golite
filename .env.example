# ==============================================================================
# KONFIGURASI WABOT KREDENSIAL (LENGKAP & AMAN)
# ==============================================================================

# 1. Konfigurasi Server Utama & Database Lokal
APP_PORT=5007
DB_NAME=wa_asli.db

# 2. Keamanan API Kustom
WABOT_API_KEY=akang-hendi-secret-wabot-key

# 3. Endpoint URL Internal Sistem
API_SOURCE_REMINDER=http://127.0.0.1:7007/api/v1/wabot/reminder
API_INTERNAL_SEND=http://127.0.0.1:5007/api/send

# 4. Pengaturan Batas Toleransi Pengiriman WA
MAX_RETRY_KIRIM=5
SEND_DELAY_SECONDS=3

# 5. Pengaturan Sinkronisasi Jeda Waktu Heartbeat (Default: 10 Detik)
SYNC_INTERVAL=10s

# 6. Pengaturan Jendela Pengiriman WA (Port Listener API)
LISTENER_PORT=5008

# ==============================================================================
# 7. PENGATURAN LOGGING (Pilih salah satu: DEBUG, INFO, WARNING, ERROR)
# ==============================================================================
# DEBUG   : Menampilkan semua aktivitas, termasuk denyut cron dan ping API
# INFO    : Menampilkan info standar (Berhasil tarik data, pesan terkirim)
# WARNING : Hanya menampilkan peringatan jika format cron salah
# ERROR   : Sangat sepi, hanya muncul jika ada kegagalan sistem/database
LOG_LEVEL=DEBUG