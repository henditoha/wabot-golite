# Whatsmeow SQLite Configuration
# Lokasi file database SQLite untuk menyimpan sesi WhatsApp
WHATSAPP_DB_PATH=wa_asli.db

# Konfigurasi API
API_USER=HP11User
API_PASS=HP11Passwd
API_URL=http://localhost/hpiibanten/api_peserta.php

# Interval Pengecekan (Gunakan format s=detik, m=menit, h=jam)
SYNC_INTERVAL=10s

# Port Server API Lokal (Gateway)
LISTENER_PORT=5008